# TrendPulse AI - Environment Variables
# Copy this file to .env and fill in your API keys

# ============================================
# REQUIRED
# ============================================

# Google Gemini API Key (for trend search & analysis)
# Get yours at: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# ============================================
# OPTIONAL (mock data used when missing)
# ============================================

# Semrush API Key (for SEO keyword intelligence)
# Get yours at: https://www.semrush.com/api/
VITE_SEMRUSH_API_KEY=

# Facebook Ads Library API Token (for competitor ad intelligence)
# Requires: Business Manager > System User > ads_read permission
# Setup guide: https://www.facebook.com/ads/library/api/?source=onboarding
VITE_FB_ADS_TOKEN=
